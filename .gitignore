# W235 — daemon-generated transient fuzz exploration corpora.
# Long-lived seed-corpora live under reports/fuzz/seed-corpus/<spec>/ (tracked).
# Per-run exploration dumps under spec-corpus-<unix_ms>/ are ephemeral.
reports/fuzz/seed-corpus/spec-corpus-*/

# ─── Python ───────────────────────────────────────────────────────────
# Universal parse_par (W4.2) is pure Python — bytecode is per-machine.
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── W-SANITIZE — vendor-sensitive data stays LOCAL only ─────────────
# Per Boki's rule "matematika ne sme da procuri nigde", raw vendor PAR
# dumps and all derived artifacts must NEVER be tracked in git. These
# directories are regenerated locally from non-committed source data.
games/*/raw/
games/*/out/
games/*/reports/
games/*/engine-rust/target/
games/*/engine-ts/dist/
games/*/engine-ts/node_modules/

# W4.8 + W4.10 — slot-sim universal IR for Skeleton Key + Fortune Coin Boost
# Classic. These JSONs carry ONLY aggregate public-spec-style math facts
# (RTP, hold, hit_freq, paytable multipliers, reel weights). No raw cell
# dump — vendor cells.json + xlsx stays local under
# agents/math-agent/corpus/*/ultimate_extract/ which is gitignored above.
!games/skeleton-key/out/
!games/skeleton-key/out/*.slot-sim.ir.json
!games/fortune-coin-boost-classic/out/
!games/fortune-coin-boost-classic/out/*.slot-sim.ir.json

# ─── Ultimate PAR extracts — vendor data stays LOCAL only ───────────
# tools.par_extract_ultimate dumps every cell of every sheet, including
# raw paytables, reel strips, and weights. These NEVER leave the machine.
# The lightweight `essentials.json` / `summary.json` / `full_corpus.json`
# (already in tree) ARE fine to commit — they're derived aggregate
# fingerprints, not the raw vendor matrix.
agents/math-agent/corpus/*/ultimate_extract/
agents/math-agent/corpus/*/raw/
agents/math-agent/corpus/*/ultimate_extract.pointer.json

# QA Agent run artefacts — one directory per run, accumulates fast.
# Reports are reproducible from `make qa-quick` / `qa-full` so no value
# in keeping run-id timestamps under git history.
reports/qa_agent/

# W4.8f/W4.10f — residual gap probe + LP solver outputs.
# Reports contain vendor `rtp_breakdown` shares used as LP target_b vectors.
# Tools themselves (par_probe_residual_gap.py + par_solver_picker_weights.py)
# ARE committed — they're trajni alati for future SWID-ove. Only the per-run
# JSON outputs (which read vendor cells.json) stay local.
reports/residual_gap_probe.json
reports/picker_solver.json

# ─── Per-run timestamp churn (no semantic content) ──────────────────
# Ovi fajlovi se rebuild-uju kod svakog `npm test` / `make qa-quick` —
# u diff-u uvek samo `at` / `startedAt` / `durationMs` timestamps. Bez
# vrednosti za git history. Svi su deterministički regeneracije iz
# fixtures + RNG seed-a; bit-identical replay je već testiran u smoke.
reports/smoke/summary.json
reports/fuzz/seed-corpus/**/*.json
reports/fuzz/checkpoints/**/*.json

dist/pilot/
dist/cert/
dist/test-cert/
.venv-w73/
slot_math_engine_template.egg-info/

# W4.15 — per-SWID regulator cert bundle outputs.
# The ZIPs are large (one per SWID × 12 SWIDs) and contain derivatives of
# vendor IRs. The CLI itself (tools/cert_bundle_swid/) and the tests
# (tools/tests/test_cert_bundle_swid.py) ARE committed — they're the
# reproducible tool, not the artefact. Local runs land under:
#   reports/cert-bundle-swid/*.zip                  — emitted bundles
#   reports/cert-bundle-swid/keys/{private,public}.pem — repro signing key
#   reports/cert-bundle-swid/mc-cache/*.json        — MC result cache
reports/cert-bundle-swid/

# W5.7 — Greenfield-demo pipeline outputs.
# The `tools.greenfield_demo` CLI emits per-stage JSON + signed cert ZIP
# under reports/greenfield-demo/. The tool + GDD + tests ARE committed
# (reproducible from any checkout); only the per-run artefacts are
# local. Drop the demo directory wholesale from git.
reports/greenfield-demo/

# W6.3 — Pitch HTML + LLM demo recorder outputs.
# Both tools regenerate deterministically from any checkout (same repo
# state → bit-identical artefacts). Tracking them would noise every CI
# run. The packages (tools/pitch_report/, tools/llm_demo_recorder/) and
# the tests ARE committed — they are the reproducible source-of-truth.
reports/pitch-report/
reports/llm-demo/

# W7 — Public math-compiler benchmark.
# `tools/benchmark` regenerates results.json + results.md + benchmark.svg +
# benchmark.sha256.txt deterministically from any checkout (same engine
# binary + same generator tag → byte-identical timing-invariant hash).
# Tracking the artefacts would noise every CI run. The package and the
# acceptance tests ARE committed — they are the reproducible
# source-of-truth.
reports/benchmark/

# W244 wave 9 — reg-oracle bootstrap landed. `traces.jsonl` is now
# deterministically generated by `tools/reg_oracle/bootstrap_corpus.py`
# from `tools/jurisdiction/profiles/*.yaml` + few-shot examples and IS
# committed (117 traces, 12 jurisdictions, deterministic Merkle hash
# verified by tools/tests/test_reg_oracle_corpus.py).

# W244 — Stryker+vitest bug reproducer minimal repo.
# Standalone reproducer for an upstream bug; install + run artefacts are
# transient. The repro sources (5 files: README, GITHUB_ISSUE.md,
# package.json, stryker.config.mjs, vitest.config.ts, tsconfig.json,
# src/limits.ts, tests/limits.test.ts) ARE committed.
bug-reports/*/node_modules/
bug-reports/*/package-lock.json
bug-reports/*/.stryker-tmp/
bug-reports/*/reports/
