# ─── Build outputs ────────────────────────────────────────────────────
# TS compile artifacts — `npm run build` regenerates these on every machine.
# Tracking them in git creates a 4000-file diff every time someone runs lint.
/dist/
*.tsbuildinfo

# Rust target dir lives next to its crate.
/rust-sim/target/
/target/

# Node packages — `npm install` rebuilds from package-lock.json.
/node_modules/

# Simulation outputs — runs land here and they can be huge (CSV / HDR histograms).
/out/
/coverage/

# ─── macOS / ExFAT junk ───────────────────────────────────────────────
# The T7 external is ExFAT. Every write from macOS creates AppleDouble
# (`._foo`) twin files and Finder breadcrumbs (`.DS_Store`). They are
# binary, opaque, and break vitest if they sit next to `*.test.ts`.
.DS_Store
**/._*

# ─── Editor / IDE ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Env / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── W6.2 LLM ingest cache ────────────────────────────────────────────
# Anthropic Claude responses cached by sha256(prompt + model + schema).
# Regenerated on demand; the offline `--demo-corpus` flow re-creates
# the canonical archetype set without an API key.
reports/gdd-llm-cache/

# ─── Logs / temp ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.cache/
.tmp/

# ─── Mutation testing fat artifacts (per-mutant logs + diffs are ~44 MB) ────
reports/mutation/rust/*/mutants.out/log/
reports/mutation/rust/*/mutants.out/diff/
reports/mutation/rust/*/mutants.out/lock.json
reports/mutation/rust/*/mutants.out/debug.log

# ─── Daily cert replay output (W152 Wave 15 cert-daily.mjs) ───────────
# Per-day timestamped dossiers + HEAD/CHAIN are operator-side cron output,
# regenerated daily. Tracking them would commit-noise every CI run.
reports/acceptance/cert-daily/

# ─── GLI-19 cert bundle raw artifacts (W232) ──────────────────────────
# rng_submission generates 5 × 12 MiB raw entropy dumps + a 6 MiB source
# tarball + a 66 MiB zip. The bundle is cryptographically reproducible
# from any tagged commit via `scripts/cert-bundle.sh`, so only the
# tamper-evidence metadata (manifest.json / manifest.sha256 /
# hardware.json / README.md) needs to live in git. Raw .bin streams,
# source tarballs and zip archives stay local / lab-side.
reports/cert-bundle-*/*.bin
reports/cert-bundle-*/source-*.tar.gz
reports/slot-math-rng-cert-*.zip

# ─── Cross-platform RNG parity transient report (W152 Wave 48) ────────
# CROSS_PLATFORM_RNG_PARITY.json is regenerated on every `npm run
# cross-platform-rng-parity` run; the committed source-of-truth is
# CROSS_PLATFORM_GOLDEN.json. Tracking the transient report would create
# diff noise on every developer run.
reports/parity/CROSS_PLATFORM_RNG_PARITY.json

