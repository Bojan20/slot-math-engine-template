# from git noise. The JSON + MD reports under reports/browser-compat/ are
# the source-of-truth deliverables and stay tracked.
reports/browser-compat/*.png
.env.production

# W207 mini-app artifacts
web/docs/node_modules/
web/docs/package-lock.json
dist/docs/
mobile/node_modules/
mobile/package-lock.json
mobile/ios/Pods/
mobile/android/.gradle/
mobile/android/build/
