{
  "name": "slot-math-engine-template",
  "version": "1.0.0",
  "type": "module",
  "description": "Production-grade Slot Math Simulator Template - Reusable for any slot game",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "sim": "npm run build && node dist/index.js",
    "sim:quick": "npm run build && node dist/index.js --quick",
    "sim:full": "npm run build && node dist/index.js --spins=100000000",
    "compare": "npm run build && node dist/tools/compare.js",
    "test": "node --experimental-vm-modules node_modules/vitest/vitest.mjs run",
    "test:watch": "node --experimental-vm-modules node_modules/vitest/vitest.mjs",
    "lint": "tsc --noEmit",
    "mutate": "npx stryker run",
    "mutate:scoped": "npx stryker run stryker.scoped.config.mjs",
    "mutate:rust": "./scripts/rust-mutate.sh",
    "mutate:rust:whole": "./scripts/rust-mutate.sh --whole-crate",
    "par-samples": "npm run build && node scripts/par-samples-generate.mjs",
    "par-stress": "npm run build && node scripts/par-distribution-stress.mjs --verbose",
    "rng-quality": "npm run build && node scripts/rng-quality.mjs",
    "optimizer-reproductions": "npm run build && node scripts/optimizer-reproductions.mjs",
    "mc-corpus": "npm run build && node scripts/mc-corpus-generate.mjs",
    "mutation-summary": "node scripts/mutation-summary.mjs",
    "anomaly-timing": "npm run build && node scripts/anomaly-detection-timing.mjs",
    "optimizer-mass-validation": "npm run build && node scripts/optimizer-mass-validation.mjs",
    "sub-ms-mc-bench": "npm run build && node scripts/sub-ms-mc-bench.mjs",
    "fs-configs-acceptance": "npm run build && node scripts/fs-configs-acceptance.mjs",
    "hnw-acceptance": "npm run build && node scripts/hnw-acceptance.mjs",
    "hnw-ladder-acceptance": "npm run build && node scripts/hnw-ladder-acceptance.mjs",
    "charge-meter-acceptance": "npm run build && node scripts/charge-meter-acceptance.mjs",
    "supermeter-acceptance": "npm run build && node scripts/supermeter-acceptance.mjs",
    "sticky-cash-reveal-acceptance": "npm run build && node scripts/sticky-cash-reveal-acceptance.mjs",
    "walking-wild-respin-acceptance": "npm run build && node scripts/walking-wild-respin-acceptance.mjs",
    "megacluster-stack-ways-acceptance": "npm run build && node scripts/megacluster-stack-ways-acceptance.mjs",
    "entropy-health-monitor-acceptance": "npm run build && node scripts/entropy-health-monitor-acceptance.mjs",
    "demo-mode-acceptance": "npm run build && node scripts/demo-mode-acceptance.mjs",
    "crash-multiplier-acceptance": "npm run build && node scripts/crash-multiplier-acceptance.mjs",
    "parallel-screens-acceptance": "npm run build && node scripts/parallel-screens-acceptance.mjs",
    "class-ii-bingo-acceptance": "npm run build && node scripts/class-ii-bingo-acceptance.mjs",
    "sticky-cash-collector-acceptance": "npm run build && node scripts/sticky-cash-collector-acceptance.mjs",
    "must-hit-by-jackpot-acceptance": "npm run build && node scripts/must-hit-by-jackpot-acceptance.mjs",
    "pseudo-must-hit-level-acceptance": "npm run build && node scripts/pseudo-must-hit-level-acceptance.mjs",
    "multi-tier-wap-wheel-acceptance": "npm run build && node scripts/multi-tier-wap-wheel-acceptance.mjs",
    "bonus-buy-variance-acceptance": "npm run build && node scripts/bonus-buy-variance-acceptance.mjs",
    "closed-form-portfolio": "npm run build && node scripts/closed-form-portfolio.mjs",
    "exact-enumeration": "node scripts/exact-enumeration.mjs",
    "cluster-cascade-acceptance": "npm run build && node scripts/cluster-cascade-acceptance.mjs",
    "test-coverage": "node scripts/test-coverage-report.mjs",
    "chi-squared-sizes": "node scripts/chi-squared-sizes-report.mjs",
    "random-config-sweep": "npm run build && node scripts/random-config-sweep.mjs",
    "billion-spins-replay": "npm run build && node --max-old-space-size=4096 scripts/billion-spins-replay.mjs",
    "both-ways-acceptance": "npm run build && node scripts/both-ways-acceptance.mjs",
    "varrows-cascade-acceptance": "npm run build && node scripts/varrows-cascade-acceptance.mjs",
    "sales-demo": "npm run build && node scripts/sales-demo.mjs",
    "sales-demo:quick": "npm run build && node scripts/sales-demo.mjs --quick",
    "behaviors-compositional": "npm run build && node scripts/behaviors-compositional-acceptance.mjs",
    "metamorphic-rtp": "npm run build && node scripts/metamorphic-rtp-invariants.mjs",
    "mutation-gate": "node scripts/mutation-gate.mjs",
    "mutation-gate:strict": "node scripts/mutation-gate.mjs --strict",
    "mutation-gate:update-baseline": "node scripts/mutation-gate.mjs --update-baseline",
    "usif-par-validate": "node scripts/usif-par-validate.mjs",
    "usif-par-validate:strict": "node scripts/usif-par-validate.mjs --strict-tier1",
    "jurisdiction-auto-gate": "npm run build && node scripts/jurisdiction-auto-gate-acceptance.mjs",
    "diff-fuzz-cross-lang": "npm run build && node scripts/diff-fuzz-cross-language.mjs",
    "sp80090b-assess": "npm run build && node scripts/sp80090b-assess.mjs",
    "par-commitment-acceptance": "npm run build && node scripts/par-commitment-acceptance.mjs",
    "industry-first-dossier": "node scripts/industry-first-dossier.mjs",
    "ent-assess": "npm run build && node scripts/ent-assess.mjs",
    "operator-package": "node scripts/operator-package.mjs",
    "operator-package:cached": "node scripts/operator-package.mjs --skip-acceptance",
    "par-samples-extra-credit": "npm run build && node scripts/par-samples-extra-credit.mjs",
    "industry-patterns": "npm run build && node scripts/industry-patterns-acceptance.mjs",
    "par-sample-kit": "node scripts/par-sample-kit-build.mjs",
    "par-sample-kit:verify": "node scripts/par-sample-kit-acceptance.mjs",
    "cross-platform-rng-parity": "npm run build && node scripts/cross-platform-rng-parity.mjs",
    "cross-platform-rng-parity:update-golden": "npm run build && node scripts/cross-platform-rng-parity.mjs --update-golden"
  },
  "author": "Slot Math Engine Team",
  "license": "MIT",
  "devDependencies": {
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.17.6",
    "pdfkit": "^0.18.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "commander": "^14.0.2",
    "decimal.js": "^10.6.0",
    "fast-check": "^4.5.2",
    "fast-csv": "^5.0.5",
    "hdr-histogram-js": "^3.0.1",
    "piscina": "^5.1.4",
    "xxhash-wasm": "^1.1.0",
    "zod": "^4.2.1"
  }
}
