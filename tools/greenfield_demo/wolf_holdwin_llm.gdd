# GDD generated by W6.2 LLM ingest.
# Deterministic: same prompt + same schema_version =>
# bit-identical YAML.  Do not hand-edit.
# archetype: hold_and_win
# swid: 200-9999-071

schema_version: "1.0.0"

meta:
  name: "Wolf Fireball HW LLM"
  vendor: "studio-internal"
  swid: 200-9999-071
  author: "gdd-llm-ingest@studio"
  description: "Generated by W6.2 LLM ingest from NL prompt; archetype=hold_and_win."
  theme_tags: [wolf, fireball, mythic]

topology:
  kind: rectangular
  reels: 5
  rows: 3

symbols:
  - id: wild
    kind: wild
    substitutes: *
  - id: scatter
    kind: scatter
  - id: hp_wolf
    kind: hp
  - id: hp_fireball
    kind: hp
  - id: hp_moon
    kind: hp
  - id: hp_totem
    kind: hp
  - id: lp_a
    kind: lp
  - id: lp_k
    kind: lp
  - id: lp_q
    kind: lp
  - id: lp_j
    kind: lp

features:
  - kind: free_spins
    trigger_count_min: 3
    initial_spins: 5
    global_multiplier: 1
  - kind: hold_and_win
    trigger_count_min: 6
    respins_initial: 3

paylines: 20

constraints:
  target_rtp: 0.960000
  rtp_tolerance: 0.005000
  volatility_class: medium
  hit_freq_target: 0.210000
  max_win_x: 5000
  jurisdictions: [UKGC, MGA, ADM]
  pay_ladder_monotonic: true
  pay_min: 0.200000
  pay_max: 1000

hints:
  reel_length: 50
  wild_share: 0.040000
  scatter_share: 0.020000
